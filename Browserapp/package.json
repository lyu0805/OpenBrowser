{
  "name": "openbrowser",
  "productName": "OpenBrowser",
  "version": "1.0.1",
  "description": "OpenBrowser：本地浏览器环境、扩展与窗口同步管理器",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "node scripts/run-app.js",
    "selftest": "node environment-audit-selftest.js",
    "selftest:automation": "node automation/automation-selftest.js",
    "selftest:protocol": "node automation/protocol/protocol-selftest.js",
    "selftest:isolation": "node automation/isolation-fingerprint-selftest.js",
    "selftest:kernel": "node automation/kernel-policy-selftest.js",
    "selftest:startup": "node browser-startup-diagnostic-selftest.js",
    "selftest:cloud": "node automation/cloud-sync-security-selftest.js",
    "log:startup": "node scripts/read-startup-log.js",
    "log:fingerprint": "node scripts/read-fp-log.js",
    "prepare:bundled-kernel": "node scripts/prepare-bundled-kernel.js",
    "build:native": "node scripts/build-native.js",
    "package:portable": "node scripts/package-portable.js",
    "selftest:theme": "node theme-nes-light-selftest.js",
    "selftest:retro": "node theme-retro-desktop-selftest.js",
    "selftest:themes": "node theme-nes-light-selftest.js && node theme-retro-desktop-selftest.js"
  },
  "devDependencies": {
    "desktop-shell": "npm:electron@43.1.1",
    "rcedit": "5.0.2"
  }
}
